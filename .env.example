# SMTP credentials for the contact form (server/api/contact.post.ts).
#
# Recommended: use your own Gmail account via an App Password - zero third-party
# signup, no domain/sender verification needed, since you're sending from a mailbox
# you already own.
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      (choose "Mail" as the app - Google gives you a 16-character password)
#   3. Use that password below (remove any spaces Google shows it with)
NUXT_SMTP_HOST=smtp.gmail.com
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=your-gmail-address@gmail.com
NUXT_SMTP_PASS=your-16-character-app-password

# Where contact form submissions should be delivered.
NUXT_CONTACT_TO_EMAIL=efondocherryeam@gmail.com

# The "from" address on outgoing emails. Defaults to NUXT_CONTACT_TO_EMAIL if unset.
# With Gmail SMTP this should just be the same Gmail address as NUXT_SMTP_USER.
NUXT_CONTACT_FROM_EMAIL=efondocherryeam@gmail.com

# --- Alternative: Brevo (higher volume, but requires verifying a sender) ---
# NUXT_SMTP_HOST=smtp-relay.brevo.com
# NUXT_SMTP_PORT=587
# NUXT_SMTP_USER=your-brevo-login@smtp-brevo.com
# NUXT_SMTP_PASS=your-brevo-smtp-key
